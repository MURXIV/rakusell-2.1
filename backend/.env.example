SECRET_KEY=change-me-generate-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1
CORS_ALLOWED_ORIGINS=https://example.com

DATABASE_URL=postgres://rakusell:rakusell_pass@localhost:5432/rakusell

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Green-API — регистрация на green-api.com, создать инстанс и вставить ID и токен
GREEN_API_INSTANCE_ID=710XXXXXXX
GREEN_API_TOKEN=<токен из личного кабинета green-api.com>
GREEN_API_BASE_URL=https://api.green-api.com

# AI-провайдер: deepseek / openai / gemini
AI_PROVIDER=deepseek
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=1000
AI_HISTORY_LIMIT=20
AI_PROMPT_SCENARIO=sales
AI_TIMEOUT_SECONDS=25
MESSAGE_GROUPING_SECONDS=25
BOT_TIME_ZONE=Asia/Qyzylorda
RESPOND_TO_GROUPS=False

# API-ключи провайдеров (нужен только тот, который указан в AI_PROVIDER)
DEEPSEEK_API_KEY=<ключ из platform.deepseek.com>
OPENAI_API_KEY=
GEMINI_API_KEY=

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=rakusell_knowledge

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
WEBHOOK_SECRET=change-me-random-webhook-secret

# Field-level encryption key for Message.content and Client.phone/context_summary
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=generate-with-fernet-generate-key

RAG_DISTANCE_THRESHOLD=0.7
RAG_TOP_K=5
RAG_EMBEDDING_PROVIDER=local
RAG_EMBEDDING_MODEL=text-embedding-3-small
